{
  "expo": {
    "name": "Canupls",
    "slug": "canupls",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "canupls",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F9FA"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.canupls.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Track tasks near you",
        "NSLocationAlwaysUsageDescription": "Real-time task tracking",
        "NSCameraUsageDescription": "Upload receipt photos",
        "NSPhotoLibraryUsageDescription": "Select receipt images"
      },
      "config": {
        "googleMapsApiKey": "AIzaSyCLjcGkJa5sJ6ufCtAAwQV8L-bRJJbsLNo"
      }
    },
    "android": {
      "package": "com.canupls.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0047AB"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "edgeToEdgeEnabled": true,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCLjcGkJa5sJ6ufCtAAwQV8L-bRJJbsLNo"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Canupls to use your location for real-time task tracking."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "web": {
      "output": "single",
      "bundler": "metro"
    }
  }
}
